<script>
  $(document).ready(function () {
    $('#leaderboard').DataTable({
      // Default sort: Overall score descending (column index 3)
      order: [[3, 'desc']],

      // Columns where sorting doesn't make sense
      columnDefs: [
        { orderable: false, targets: [0] },   // rank, model, type
        { type: 'num', targets: [4, 5, 6, 7] },     // score columns → numeric sort
        { type: 'str', targets: [1, 2]}
      ],

      // Page length options
      // lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
      // pageLength: 25,
      paging: false,
      searching: false,
      info: false,

      // Layout: put search top-right, length top-left, info/pagination bottom
      // layout: {
      //   topStart: 'pageLength',
      //   topEnd: 'search',
      //   bottomStart: 'info',
      //   bottomEnd: 'paging',
      // },

      // Re-number the rank column after each sort so it always reflects
      // visual position (optional — remove if you want stable rank numbers)
      drawCallback: function () {
        this.api().column(0).nodes().each(function (cell, i) {
          const medals = ['1', '2', '3'];
          const classes = ['rank-gold', 'rank-silver', 'rank-bronze'];
          if (i < 3) {
            cell.innerHTML = `<span class="${classes[i]}">${medals[i]}</span>`;
          } else {
            cell.innerHTML = i + 1;
          }
        });
      },
    });
  });
</script>
